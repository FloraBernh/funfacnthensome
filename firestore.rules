// Firestore Security Rules for Fun Facts N Then Some
// Klistra in dessa i Firebase Console → Firestore Database → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Klick-räknare per fakta — alla får läsa och inkrementera
    match /factStats/{factKey} {
      allow read: if true;
      allow write: if true;
    }
  }
}
